# ============================================================
# Discord Bot API Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Your deployed URL (used in SDK snippets and short URL generation)
BASE_URL=https://your-domain.com

# OpenAI API key — required for /api/ai/chat to use real AI
# Without this, the AI endpoint returns a demo response
OPENAI_API_KEY=sk-...

# Session secret (optional, for signed cookies)
SESSION_SECRET=change-me-to-something-random

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Database (optional — currently uses in-memory storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/botapi

# Email provider (optional — for /api/verify/email/send)
# SENDGRID_API_KEY=SG...
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# SMS provider (optional — for /api/verify/phone/send)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890
